---
import Share from "@/components/Share.astro";
import SimilarPosts from "@/components/SimilarPosts.astro";
import Giscus from "@/components/Giscus.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import similerItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

const posts = await getSinglePage("posts");
const { post } = Astro.props;
const similarPosts = similerItems(post, posts, post.slug);
const { Content } = await render(post);
const { title, description, categories, image, thumbnail, date, tags } = post.data;
const headerImage = thumbnail || image;

// 이전글/다음글: 동일 카테고리 내에서만 이동
const categoryKey = slugify((categories && categories[0]) || "");
const sameCategoryPosts = posts
  .filter((p) => (p.data.categories || []).some((c) => slugify(c) === categoryKey))
  .sort((a, b) => {
    const ad = a.data.date ? new Date(a.data.date).getTime() : 0;
    const bd = b.data.date ? new Date(b.data.date).getTime() : 0;
    return bd - ad; // 최신순
  });
const currentIndex = sameCategoryPosts.findIndex((p) => p.id === post.id);
const nextPost = currentIndex > 0 ? sameCategoryPosts[currentIndex - 1] : null; // 더 최신 글
const prevPost =
  currentIndex >= 0 && currentIndex < sameCategoryPosts.length - 1
    ? sameCategoryPosts[currentIndex + 1]
    : null; // 더 이전 글
---

<section class="section">
  <div class="container">
    <article class="row justify-center">
      <div class="md:col-10 text-center">
        <h1 set:html={markdownify(title)} class="h2" />
        <ul class="mt-4 flex flex-wrap items-center justify-center text-text">
          <li class="mx-3 flex items-center flex-wrap font-medium">
            <BiCalendarEdit className="mr-1 h-5 w-5 text-gray-600" />
            {dateFormat(date)}
          </li>
          <li class="mx-3 flex items-center flex-wrap">
            <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-gray-600" />

            <ul>
              {
                categories.map((category: string, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-medium"
                    >
                      {humanize(category)}
                      {i !== post.data.categories.length - 1 && ","}
                    </a>
                  </li>
                ))
              }
            </ul>
          </li>
        </ul>
      </div>

      <div class="col-12 mt-8 mb-2">
        {
          headerImage && (
            <Image
              src={headerImage}
              height={500}
              width={1000}
              alt={title}
              class="rounded-lg shadow-[0_4px_20px_rgba(0,0,0,0.12)] mb-8"
            />
          )
        }
      </div>

      <div class="md:col-10">
        <div class="content mb-16 text-left">
          <Content />
        </div>

        <div class="flex flex-wrap items-center justify-between">
          <ul class="mr-4 mb-4 space-x-3">
            {
              tags.map((tag: string) => (
                <li class="inline-block">
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="block rounded-lg bg-light px-4 py-2 font-semibold text-dark text-sm hover:text-primary transition duration-300"
                  >
                    #{humanize(tag)}
                  </a>
                </li>
              ))
            }
          </ul>
          <Share
            className="social-share mb-4"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>

        {/* prev/next: tags+share 아래, giscus 위 */}
        {
          (prevPost || nextPost) && (
            <div class="mt-6 mb-10 grid grid-cols-1 sm:grid-cols-2 gap-4">
              {prevPost && (
                <a
                  href={`/${prevPost.id}`}
                  class="prev-next-card group block rounded-2xl bg-white p-6 shadow-[0_1px_0_rgba(15,23,42,0.04)] ring-1 ring-inset ring-slate-200/70 transition-colors duration-200 hover:bg-primary/5 hover:ring-primary/30"
                >
                  <div class="prev-next-meta flex items-center gap-2 text-xs font-semibold text-slate-600">
                    <span class="prev-next-arrow">
                      ←
                    </span>
                    <span>이전 글</span>
                  </div>
                  <p class="mt-3 text-dark font-semibold line-clamp-2 min-h-[3rem] group-hover:text-primary transition-colors duration-200">
                    {prevPost.data.title}
                  </p>
                </a>
              )}

              {nextPost && (
                <a
                  href={`/${nextPost.id}`}
                  class={
                    "prev-next-card group block rounded-2xl bg-white p-6 shadow-[0_1px_0_rgba(15,23,42,0.04)] ring-1 ring-inset ring-slate-200/70 transition-colors duration-200 hover:bg-primary/5 hover:ring-primary/30 text-right " +
                    (!prevPost ? "sm:col-start-2" : "")
                  }
                >
                  <div class="prev-next-meta flex items-center justify-end gap-2 text-xs font-semibold text-slate-600">
                    <span>다음 글</span>
                    <span class="prev-next-arrow">
                      →
                    </span>
                  </div>
                  <p class="mt-3 text-dark font-semibold line-clamp-2 min-h-[3rem] group-hover:text-primary transition-colors duration-200">
                    {nextPost.data.title}
                  </p>
                </a>
              )}
            </div>
          )
        }
      </div>
    </article>
  </div>
</section>

<!-- comments -->
<section class="section pt-0">
  <div class="container">
    <div class="md:col-10 mx-auto">
      <Giscus />
    </div>
  </div>
</section>

<!-- similar posts -->
{
  similarPosts.length > 0 && (
    <section class="section pt-0">
      <div class="container">
        <h2 class="mb-8 text-center h3">Similar Posts</h2>
        <SimilarPosts posts={similarPosts.slice(0, 3)} />
      </div>
    </section>
  )
}
