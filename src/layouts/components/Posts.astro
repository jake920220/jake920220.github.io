---
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { BiCalendarEdit, BiCategoryAlt } from "react-icons/bi";

type Props = {
  posts: CollectionEntry<"posts">[];
  className?: string;
  fluid?: boolean;
};

const { className, posts, fluid } = Astro.props;

function isBookReview(post: CollectionEntry<"posts">) {
  return (post.data.categories || []).some((c) => slugify(c) === "book-review");
}

function isTech(post: CollectionEntry<"posts">) {
  return (post.data.categories || []).some((c) => slugify(c) === "tech");
}

function getBookThumb(post: CollectionEntry<"posts">) {
  return post.data.thumbnail || post.data.image || "/images/posts/book.png";
}

function getExcerpt(post: CollectionEntry<"posts">) {
  const manual = (post.data as any).excerpt;
  if (manual && String(manual).trim().length > 0) return String(manual).trim();
  const desc = (post.data as any).description;
  if (desc && String(desc).trim().length > 0) return String(desc).trim();
  const text = plainify(post.body ?? "").replace(/\s+/g, " ").trim();
  return text.length > 160 ? `${text.slice(0, 160).trim()}…` : text;
}


---

<div
  class={`row gy-5 gx-4 ${className} ${posts.length == 1 ? "justify-center" : ""} `}
>
  {
    posts.map((post, i: number) => {
      const book = isBookReview(post);
      const dev = isTech(post);
      const w = i === 0 && fluid != false ? 925 : 445;
      const h = i === 0 && fluid != false ? 475 : 230;

      return (
        <div
          class={i === 0 && fluid != false ? "col-12" : "col-12 sm:col-6"}
          data-post-categories={post.data.categories
            .map((c) => slugify(c))
            .join(",")}
          data-post-tags={post.data.tags.map((t) => slugify(t)).join(",")}
        >
          <a
            href={`/${post.id}`}
            class="rounded-lg block hover:text-primary overflow-hidden group"
          >
            {
              book ? (
                <div class="w-full aspect-[16/9] relative overflow-hidden rounded-lg bg-white border border-slate-200 shadow-[0_1px_0_rgba(15,23,42,0.02)]">
                  {/* subtle paper tint */}
                  <div class="absolute inset-0 bg-[radial-gradient(120%_120%_at_10%_10%,rgba(248,250,252,0.95)_0%,rgba(255,255,255,0.9)_45%,rgba(241,245,249,0.8)_100%)]" />
                  <div class="absolute inset-0 opacity-[0.035] mix-blend-multiply bg-[repeating-linear-gradient(0deg,rgba(15,23,42,0.08)_0,rgba(15,23,42,0.08)_1px,transparent_1px,transparent_3px)]" />

                  <div class="absolute left-3 top-3 z-20">
                    <span class="inline-flex items-center rounded-full border border-slate-200 bg-white/70 px-2 py-0.5 text-[11px] font-medium text-slate-600 backdrop-blur-sm">
                      서평
                    </span>
                  </div>

                  <div class="relative z-10 h-full w-full flex items-center justify-center">
                    <img
                      src={getBookThumb(post)}
                      alt={post.data.title}
                      loading="lazy"
                      class="h-[78%] w-auto object-contain rounded-md shadow-[0_8px_18px_rgba(15,23,42,0.12)] group-hover:scale-[1.03] transition duration-300"
                    />
                  </div>
                </div>
              ) : dev ? (
                post.data.image && (
                  <div class="w-full aspect-[16/9] relative overflow-hidden rounded-lg bg-slate-100 border border-slate-200">
                    <div class="absolute left-3 top-3 z-20">
                      <span class="inline-flex items-center rounded-full border border-slate-200 bg-white/70 px-2 py-0.5 text-[11px] font-medium text-slate-600 backdrop-blur-sm dark:border-slate-700 dark:bg-slate-900/50 dark:text-slate-200">
                        기술
                      </span>
                    </div>

                    <Image
                      class="h-full w-full object-cover group-hover:scale-[1.03] transition duration-300"
                      src={post.data.image}
                      alt={post.data.title}
                      width={w}
                      height={h}
                    />
                  </div>
                )
              ) : (
                post.data.image && (
                  <Image
                    class="group-hover:scale-[1.03] transition duration-300 w-full"
                    src={post.data.image}
                    alt={post.data.title}
                    width={w}
                    height={h}
                  />
                )
              )
            }
          </a>

          <ul class="mt-6 mb-4 flex flex-wrap items-center text-text">
            <li class="mr-5 flex items-center flex-wrap font-medium">
              <BiCalendarEdit className="mr-1 h-5 w-5 text-gray-600" />
              {dateFormat(post.data.date!)}
            </li>
            <li class="mr-5 flex items-center flex-wrap">
              <BiCategoryAlt className="mr-1 h-[18px] w-[18px] text-gray-600" />

              <ul>
                {post.data.categories.map((category, i: number) => (
                  <li class="inline-block">
                    <a
                      href={`/categories/${slugify(category)}`}
                      class="mr-2 hover:text-primary font-medium"
                    >
                      {slugify(category) === "tech" ? "Tech" : humanize(category)}
                      {i !== post.data.categories.length - 1 && ","}
                    </a>
                  </li>
                ))}
              </ul>
            </li>
          </ul>

          <h3 class="mb-3">
            <a
              href={`/${post.id}`}
              class="block hover:text-primary transition duration-300"
            >
              {post.data.title}
            </a>
          </h3>
          <ul class="mb-3 flex flex-wrap gap-2">
            {post.data.tags.slice(0, 4).map((tag: string) => (
              <li class="inline-block">
                <a
                  href={`/tags/${slugify(tag)}`}
                  class="block rounded-lg bg-light px-3 py-1 font-semibold text-dark text-xs hover:text-primary transition duration-300"
                >
                  #{humanize(tag)}
                </a>
              </li>
            ))}
          </ul>
          <p class="text-text line-clamp-2">{getExcerpt(post)}</p>
        </div>
      );
    })
  }
</div>
