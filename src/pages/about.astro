---
import Base from "@/layouts/Base.astro";
import config from "@/config/config.json";
import { markdownify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { getEntry, render } from "astro:content";

const entry = (await getEntry("about", "-index")) as CollectionEntry<"about">;
const { Content } = await render(entry);
const { title, meta_title, description, image, what_i_do } = entry.data;

const canonical = `${config.site.base_url}/about`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "김준현",
  url: config.site.base_url,
  jobTitle: ["프론트엔드 개발자", "웹 프로그래밍 강사"],
  email: "mailto:kimjun8jun8@gmail.com",
};

const iconMap: Record<string, string> = {
  Teaching: "🎓",
  "Frontend Development": "🧩",
  "Book Reviews": "📚",
  Writing: "✍️",
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
  canonical={canonical}
  jsonLd={jsonLd}
>
  {/* Hero */}
  <section class="section pb-0">
    <div class="container">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-10 shadow-[0_6px_20px_rgba(15,23,42,0.06)]">
        <div class="row gy-8 items-center md:gx-8">
          <div class="col-12 sm:col-5 md:col-4">
            {
              image && (
                <div class="img-cover">
                  <Image
                    src={image}
                    width={420}
                    height={420}
                    alt={title}
                    class="rounded-2xl w-full object-cover"
                  />
                </div>
              )
            }
          </div>

          <div class="col-12 sm:col-7 md:col-8">
            <p class="text-sm font-medium text-slate-500 mb-2 mt-4 sm:mt-0">About</p>
            <h1
              set:html={markdownify(title)}
              class="text-2xl md:text-3xl font-semibold tracking-tight leading-snug mb-4"
            />
            <p class="text-text leading-relaxed">
              "준현의 기록"은 <strong>읽고 만드는 개발자</strong>의 시선으로 서평과 기술을 기록하는 공간이에요.
              강의/개발/독서를 하며 얻은 인사이트를 정리해요.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* What I do */}
  <section class="section">
    <div class="container">
      <h2 class="page-heading mb-14">{what_i_do.title}</h2>

      <div class="row gy-4">
        {what_i_do.items.map((item: any) => (
          <div class="col-12 md:col-6">
            <div class="h-full rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_6px_20px_rgba(15,23,42,0.05)] relative overflow-hidden">
              <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-primary/60 via-primary/20 to-transparent" />
              <div class="flex items-start gap-4">
                <div class="h-11 w-11 shrink-0 rounded-xl bg-slate-50 border border-slate-200 flex items-center justify-center text-xl">
                  {iconMap[item.title] || "✨"}
                </div>
                <div>
                  <h3 class="text-lg font-semibold mb-1">{item.title}</h3>
                  <p class="text-text leading-relaxed mb-0">{item.description}</p>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* Bio content */}
  <section class="section pt-0">
    <div class="container">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-10 shadow-[0_6px_20px_rgba(15,23,42,0.06)]">
        <div class="content about-content">
          <Content />
        </div>
      </div>
    </div>
  </section>
</Base>
>
    <div class="container">
      <div class="rounded-2xl border border-slate-200 bg-white p-6 md:p-10 shadow-[0_6px_20px_rgba(15,23,42,0.06)]">
        <div class="content about-content">
          <Content />
        </div>
      </div>
    </div>
  </section>
</Base>
