---
import Base from "@/layouts/Base.astro";
import Posts from "@/components/Posts.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);

const techPosts = sortedPosts.filter((p) =>
  (p.data.categories || []).some((c: string) => c.toLowerCase() === "tech"),
);
---

<Base title={"Tech"} meta_title={"준현의 기록 | Tech"}>
  <section class="section">
    <div class="container">
      <div class="mb-10">
        <h1 class="h2 mb-2">Tech</h1>
        <p class="text-text">개발과 자동화, 운영 과정에서 마주한 문제와 해결의 흔적을 기록합니다.</p>
      </div>
      <Posts posts={techPosts} />
    </div>
  </section>
</Base>
