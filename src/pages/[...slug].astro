---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import PostSingle from "@/partials/PostSingle.astro";

export async function getStaticPaths() {
  const BLOG_FOLDER = "posts";
  const posts = await getSinglePage(BLOG_FOLDER);

  const paths = posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: { post },
  }));
  return paths;
}

const { post } = Astro.props;
const { title, meta_title, image, thumbnail, description, date, authors } = post.data;

const siteUrl = import.meta.env.SITE || "https://jake920220.github.io";
const url = `${siteUrl}/${post.id}`;
const ogImage = thumbnail || image;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description,
  image: ogImage ? [`${siteUrl}${ogImage}`] : undefined,
  datePublished: date ? new Date(date).toISOString() : undefined,
  dateModified: date ? new Date(date).toISOString() : undefined,
  author: (authors && authors.length)
    ? authors.map((a) => ({ "@type": "Person", name: a }))
    : [{ "@type": "Person", name: "김준현" }],
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": url,
  },
};
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={ogImage}
  canonical={url}
  jsonLd={jsonLd}
>
  <PostSingle post={post} />
</Base>
